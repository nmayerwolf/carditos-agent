{
  "name": "carditos-agent",
  "version": "0.1.0",
  "description": "Agente conversacional de rugby para el Club San Andrés sobre WhatsApp",
  "private": true,
  "engines": {
    "node": ">=20"
  },
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "start": "tsx src/server.ts",
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src",
    "lint:fix": "eslint src --fix",
    "format": "prettier --write src",
    "format:check": "prettier --check src",
    "test": "vitest run --passWithNoTests",
    "db:migrate": "tsx db/migrate.ts"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/nmayerwolf/carditos-agent.git"
  },
  "license": "UNLICENSED",
  "dependencies": {
    "@anthropic-ai/sdk": "^0.96.0",
    "@sentry/node": "^10.53.1",
    "@supabase/supabase-js": "^2.105.4",
    "axios": "^1.16.1",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "openai": "^6.37.0",
    "pino": "^10.3.1",
    "tsx": "^4.22.0",
    "ws": "^8.20.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/node": "^25.7.0",
    "@types/ws": "^8.18.1",
    "@typescript-eslint/eslint-plugin": "^8.59.3",
    "@typescript-eslint/parser": "^8.59.3",
    "eslint": "^10.3.0",
    "prettier": "^3.8.3",
    "typescript": "^6.0.3",
    "vitest": "^4.1.6"
  }
}
